002Fgithub.com\u002FAerunDev",{"src":52},"https:\u002F\u002Fgithub.com\u002FAerunDev.png",{"name":54,"to":55,"avatar":56},"Elliott Ventura","https:\u002F\u002Fgithub.com\u002Felliottventura",{"src":57},"https:\u002F\u002Fgithub.com\u002Felliottventura.png",{"name":59,"to":60,"avatar":61},"Scorbutics","https:\u002F\u002Fgithub.com\u002FScorbutics",{"src":62},"https:\u002F\u002Fgithub.com\u002FScorbutics.png",{"label":64},"Game Development",{"type":66,"value":67,"toc":394},"minimark",[68,73,140,144,156,168,186,189,193,254,256,260,287,312,340,364,366,370,384],[69,70,72],"h2",{"id":71},"about-the-project","About the Project",[74,75,77,125],"picture-and-text",{":card":76},"true",[78,79,80,89,90,93,94,101,102,109,110,113,114,117,118,121,122,109],"p",{},[81,82,86],"a",{"href":83,"rel":84},"https:\u002F\u002Fforet-eternelle.fr",[85],"nofollow",[87,88,41],"strong",{}," is a ",[87,91,92],{},"fan-made Pokémon game"," created with the ",[81,95,98],{"href":96,"rel":97},"https:\u002F\u002Fpokemonworkshop.com",[85],[87,99,100],{},"Pokémon SDK"," and ",[81,103,106],{"href":104,"rel":105},"https:\u002F\u002Fpsdk.pokemonworkshop.com\u002Fyard\u002FLiteRGSS.html",[85],[87,107,108],{},"LiteRGSS (Ruby)",".",[111,112],"br",{},"\nStarted in 2012, it delivers a unique Pokémon experience with a ",[87,115,116],{},"darker story",", ",[87,119,120],{},"strategic battles",", and a ",[87,123,124],{},"Pokédex of over 170 original Fakemon",[126,127,129],"template",{"v-slot:image":128},"",[78,130,131],{},[132,133],"img",{"alt":134,"className":135,"height":137,"src":138,"width":139},"main_image",[136],"rounded-lg",1280,"\u002Fimages\u002Fprojects\u002Fforet-eternelle\u002Fmain.webp",720,[69,141,143],{"id":142},"synopsis","Synopsis",[78,145,146,147,109,150,152,153,109],{},"You play as a young trainer who wins the ",[87,148,149],{},"Junior Tournament in Pallet Town",[111,151],{},"\nBut when you return home, your parents have vanished. A letter reveals the truth: they’ve been ",[87,154,155],{},"kidnapped",[78,157,158,159,162,163,165,109],{},"At nightfall, a ",[87,160,161],{},"mysterious man in black"," confronts you with a terrible condition. To save them, you must commit the unthinkable:",[111,164],{},[87,166,167],{},"steal a Pokémon from Professor Oak’s lab",[78,169,170,171,174,175,177,178,181,182,185],{},"This is the beginning of your forced infiltration into ",[87,172,173],{},"Team Rocket",", where loyalty and morality blur.",[111,176],{},"\nAcross ",[87,179,180],{},"Kanto",", the ",[87,183,184],{},"Orange Archipelago",", and beyond, your journey is shaped by choices that will test both your duty and your conscience.",[187,188],"hr",{},[69,190,192],{"id":191},"my-contributions","My Contributions",[74,194,195,200,207,241,244],{},[196,197,199],"h3",{"id":198},"enhancing-the-player-experience","Enhancing the Player Experience",[78,201,202,203,206],{},"I focused on ",[87,204,205],{},"game systems and user experience",", implementing features that make gameplay smoother, more accessible, and immersive:",[208,209,210,217,223,229,235],"ul",{},[211,212,213,216],"li",{},[87,214,215],{},"Menu UX improvements",": streamlined navigation for quicker access to key options.",[211,218,219,222],{},[87,220,221],{},"Quick-use item shortcuts",": allowing immediate item usage during exploration and battles.",[211,224,225,228],{},[87,226,227],{},"Evolutionary item integration",": ensuring new evolution mechanics were supported and balanced.",[211,230,231,234],{},[87,232,233],{},"HUD panels",": providing real-time information such as HP, status effects, or objectives.",[211,236,237,240],{},[87,238,239],{},"Discord bot development",": a community tool enabling players to fetch in-game data and information with commands.",[78,242,243],{},"Each of these contributions reduces friction and ensures players always feel connected — both in-game and in the wider community.",[126,245,246],{"v-slot:image":128},[78,247,248],{},[132,249],{"alt":250,"className":251,"height":252,"src":253,"width":252},"ux",[136],400,"\u002Fimages\u002Fprojects\u002Fforet-eternelle\u002Finventory.png",[187,255],{},[69,257,259],{"id":258},"game-features","Game Features",[74,261,262,266,278],{},[196,263,265],{"id":264},"expanding-the-universe","Expanding the Universe",[78,267,268,269,271,272,274,275,277],{},"The game reimagines classic regions like ",[87,270,180],{}," and the ",[87,273,184],{},", adding new areas, ruins, and secrets.",[111,276],{},"\nExploration is key: players uncover hidden lore, optional quests, and world-building details that enrich the adventure.",[126,279,280],{"v-slot:image":128},[78,281,282],{},[132,283],{"alt":284,"className":285,"height":139,"src":286,"width":137},"world",[136],"\u002Fimages\u002Fprojects\u002Fforet-eternelle\u002Fmap.png",[74,288,289,293,303],{":reverse":76},[196,290,292],{"id":291},"original-fakemon","Original Fakemon",[78,294,295,296,299,300,302],{},"With ",[87,297,298],{},"179 unique Fakemon",", Forêt Éternelle offers a fresh Pokédex that blends seamlessly with classic designs.",[111,301],{},"\nThese new Pokémon expand strategic options and deepen immersion for long-time fans and new players alike.",[126,304,305],{"v-slot:image":128},[78,306,307],{},[132,308],{"alt":309,"className":310,"height":139,"src":311,"width":137},"fakemon",[136],"\u002Fimages\u002Fprojects\u002Fforet-eternelle\u002Fnecropotame.webp",[74,313,314,318,331],{},[196,315,317],{"id":316},"a-darker-storyline","A Darker Storyline",[78,319,320,321,109,324,326,327,330],{},"Unlike traditional Pokémon titles, Forêt Éternelle explores themes of ",[87,322,323],{},"morality, duty, and consequence",[111,325],{},"\nThe ",[87,328,329],{},"karma system"," ensures that choices — from small interactions to major story beats — shape how the world reacts to you.",[126,332,333],{"v-slot:image":128},[78,334,335],{},[132,336],{"alt":337,"className":338,"height":252,"src":339,"width":252},"karma",[136],"\u002Fimages\u002Fprojects\u002Fforet-eternelle\u002Fcarmin-sur-mer.png",[74,341,342,346,355],{":reverse":76},[196,343,345],{"id":344},"smarter-ai","Smarter AI",[78,347,348,349,109,352,354],{},"Battles are more challenging thanks to a ",[87,350,351],{},"custom AI system",[111,353],{},"\nTrainers adapt their strategies depending on their class and team composition, forcing players to think beyond type advantages.",[126,356,357],{"v-slot:image":128},[78,358,359],{},[132,360],{"alt":361,"className":362,"height":252,"src":363,"width":252},"battle",[136],"\u002Fimages\u002Fprojects\u002Fforet-eternelle\u002Ffight.png",[187,365],{},[69,367,369],{"id":368},"community-future","Community & Future",[78,371,372,373,376,377,109,381,383],{},"Pokémon Forêt Éternelle is a ",[87,374,375],{},"non-commercial fan project",", created ",[378,379,380],"em",{},"by fans, for fans",[111,382],{},"\nCommunity feedback, testing, and creativity fuel the game’s ongoing development.",[78,385,386,387,390,391,109],{},"The journey is far from over: the goal is to build a complete adventure that ",[87,388,389],{},"respects the legacy of Pokémon"," while daring to take it into ",[87,392,393],{},"new, unexplored territory",{"title":128,"searchDepth":395,"depth":395,"links":396},2,[397,398,399,403,409],{"id":71,"depth":395,"text":72},{"id":142,"depth":395,"text":143},{"id":191,"depth":395,"text":192,"children":400},[401],{"id":198,"depth":402,"text":199},3,{"id":258,"depth":395,"text":259,"children":404},[405,406,407,408],{"id":264,"depth":402,"text":265},{"id":291,"depth":402,"text":292},{"id":316,"depth":402,"text":317},{"id":344,"depth":402,"text":345},{"id":368,"depth":395,"text":369},null,"Since 2012, Forêt Éternelle is a fan game project that aims to create an original and mature Pokémon adventure.","md",{"src":414},"\u002Fimages\u002Fprojects\u002Fforet-eternelle\u002Fforest.png","Ruby, Go",{},true,"\u002Fprojects\u002Fforet-eternelle",{"title":41,"description":411},"2024-01-25T00:00:00.000Z","3.projects\u002F004.foret-eternelle","https:\u002F\u002Fwww.pokemonforeteternelle.com\u002F","FCnpRiyAOFsr-KEgOH3kp4pCVFYrdRh_dXDz2p_scsc",[425,430],{"title":426,"path":427,"stem":428,"description":429,"children":-1},"Coco Bot","\u002Fprojects\u002Fcoco-bot","3.projects\u002F003.coco-bot","Create vertical videos clip from YouTube videos using AI.",{"title":431,"path":432,"stem":433,"description":434,"children":-1},"AIctron","\u002Fprojects\u002Faictron","3.projects\u002F005.aictron","Web application for predictive data analysis using Machine Learning",1773409594553]