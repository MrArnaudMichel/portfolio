13,145,149,163,167],[54,55,57],"h2",{"id":56},"overview","Overview",[59,60,61],"p",{},"Chess.rs is a chess game application built entirely in Rust using GTK-RS for the graphical user interface. This project demonstrates the power of Rust's memory safety and performance characteristics combined with GTK's mature GUI toolkit to create a fully functional chess game.",[59,63,64],{},"The application provides a complete chess experience with a clean, intuitive interface and all standard chess rules implemented, including special moves like castling, en passant, and pawn promotion.",[54,66,68],{"id":67},"key-features","Key Features",[70,71,73],"h3",{"id":72},"chess-engine","Chess Engine",[75,76,77,85,91,97,103],"ul",{},[78,79,80,84],"li",{},[81,82,83],"strong",{},"Complete rule implementation",": All standard chess rules including check, checkmate, and stalemate detection",[78,86,87,90],{},[81,88,89],{},"Move validation",": Real-time validation of legal moves for each piece",[78,92,93,96],{},[81,94,95],{},"Special moves",": Support for castling, en passant, and pawn promotion",[78,98,99,102],{},[81,100,101],{},"Game state management",": Tracking of game history, captured pieces, and turn management",[78,104,105,108],{},[81,106,107],{},"Checkmate detection",": Automatic detection of checkmate and stalemate conditions",[70,110,112],{"id":111},"user-interface","User Interface",[75,114,115,121,127,133,139],{},[78,116,117,120],{},[81,118,119],{},"GTK-RS based GUI",": Modern, native-looking interface built with GTK4",[78,122,123,126],{},[81,124,125],{},"Interactive board",": Click-to-move interface with visual feedback",[78,128,129,132],{},[81,130,131],{},"Move highlighting",": Visual indicators for possible moves and selected pieces",[78,134,135,138],{},[81,136,137],{},"Status display",": Current player turn, check status, and captured pieces",[78,140,141,144],{},[81,142,143],{},"Game history",": Complete move history with navigation",[70,146,148],{"id":147},"game-management","Game Management",[75,150,151,157],{},[78,152,153,156],{},[81,154,155],{},"New game",": Start a new game at any time",[78,158,159,162],{},[81,160,161],{},"Move undo\u002Fredo",": Navigate through game history",[54,164,166],{"id":165},"technology-stack","Technology Stack",[168,169,170,180,188],"card-group",{},[171,172,177],"card",{"icon":173,"target":174,"title":175,"to":176},"i-simple-icons:rust","_blank","Rust","https:\u002F\u002Fwww.rust-lang.org\u002F",[59,178,179],{},"Core programming language for both backend logic and GUI development.",[171,181,185],{"icon":182,"target":174,"title":183,"to":184},"i-simple-icons:gtk","GTK-RS","https:\u002F\u002Fgtk-rs.org\u002F",[59,186,187],{},"Rust bindings for GTK, used for building the graphical user interface.",[171,189,193],{"icon":190,"target":174,"title":191,"to":192},"i-simple-icons:gnome","Libadwaita","https:\u002F\u002Fgnome.pages.gitlab.gnome.org\u002Flibadwaita\u002Fdoc\u002Fmain\u002F",[59,194,195],{},"Used for adaptive design, responsive layout, and seamless dark\u002Flight mode support.",{"title":197,"searchDepth":198,"depth":198,"links":199},"",2,[200,201,207],{"id":56,"depth":198,"text":57},{"id":67,"depth":198,"text":68,"children":202},[203,205,206],{"id":72,"depth":204,"text":73},3,{"id":111,"depth":204,"text":112},{"id":147,"depth":204,"text":148},{"id":165,"depth":198,"text":166},null,"A chess game built with GTK-RS and Rust.","2025-07-12T00:00:00.000Z","md","https:\u002F\u002Fgithub.com\u002FMrArnaudMichel\u002Fchess-rs",{"src":214},"\u002Fimages\u002Fprojects\u002Fchessrs\u002Fcover.png",{},true,"\u002Fprojects\u002Fchess-rs","Full‑stack developer",{"title":41,"description":209},"2025-05-01T00:00:00.000Z","3.projects\u002F010.chess-rs","tvm_Dofncor2rSXYFO4i9MXPzGPzV6eLXbmA7xKSvxY",[224,229],{"title":225,"path":226,"stem":227,"description":228,"children":-1},"Moodle","\u002Fprojects\u002Fmoodle","3.projects\u002F009.moodle","Modern learning platform to manage courses, assignments, forums and users.",{"titl