[{"data":1,"prerenderedAt":325},["ShallowReactive",2],{"navigation":3,"post-turing-game":39,"surround-turing-game":314},[4,26],{"title":5,"path":6,"stem":7,"children":8,"page":25},"Schooling","\u002Fbackground\u002Fschooling","1.background\u002F1.schooling",[9,13,17,21],{"title":10,"path":11,"stem":12},"High School Education","\u002Fbackground\u002Fschooling\u002Fhighschool","1.background\u002F1.schooling\u002F001.highschool",{"title":14,"path":15,"stem":16},"Bachelor in Computer Science (BUT Informatique)","\u002Fbackground\u002Fschooling\u002Fbut","1.background\u002F1.schooling\u002F002.but",{"title":18,"path":19,"stem":20},"🇮🇪 MTU (Munster Technological University)","\u002Fbackground\u002Fschooling\u002Fmtu","1.background\u002F1.schooling\u002F003.mtu",{"title":22,"path":23,"stem":24},"UTBM (Université de Technologie de Belfort-Montbéliard)","\u002Fbackground\u002Fschooling\u002Futbm","1.background\u002F1.schooling\u002F004.utbm",false,{"title":27,"path":28,"stem":29,"children":30,"page":25},"Career","\u002Fbackground\u002Fcareer","1.background\u002F2.career",[31,35],{"title":32,"path":33,"stem":34},"Student jobs","\u002Fbackground\u002Fcareer\u002Fstudent-job","1.background\u002F2.career\u002F001.student-job",{"title":36,"path":37,"stem":38},"Internship - Assistant Engineer at FL Immo","\u002Fbackground\u002Fcareer\u002Ffl-immo","1.background\u002F2.career\u002F002.fl-immo",{"id":40,"title":41,"authors":42,"badge":58,"body":60,"date":298,"description":299,"end_date":300,"extension":301,"git_repo":302,"image":303,"main_language":304,"meta":305,"navigation":306,"path":307,"role":308,"seo":309,"start_date":310,"stem":311,"website":312,"__hash__":313},"posts\u002F3.projects\u002F008.turing-game.md","Turing Machine Game",[43,48,53],{"name":44,"to":45,"avatar":46},"Arnaud Michel","https:\u002F\u002Fgithub.com\u002FMrArnaudMichel",{"src":47},"https:\u002F\u002Fgithub.com\u002FMrArnaudMichel.png",{"name":49,"to":50,"avatar":51},"Antoine Laurant","https:\u002F\u002Fgithub.com\u002FAntoine2oo5",{"src":52},"https:\u002F\u002Fgithub.com\u002FAntoine2oo5.png",{"name":54,"to":55,"avatar":56},"Antoine Perrin","https:\u002F\u002Fgithub.com\u002FAntoinePerrin25",{"src":57},"https:\u002F\u002Fgithub.com\u002FAntoinePerrin25.png",{"label":59},"Game Development",{"type":61,"value":62,"toc":287},"minimark",[63,87,97,102,107,135,139,157,160,181,192,199,203,223,227,234,237,240,243,250,261,265,282],[64,65,66,69,70,74,75,78,79,82,83,86],"p",{},[67,68,41],"strong",{}," is a digital adaptation of the famous deduction board game ",[71,72,73],"em",{},"Turing Machine",", paying tribute to ",[67,76,77],{},"Alan Turing",", the pioneer of computer science and cryptography.",[80,81],"br",{},"\nThis version, designed at ",[67,84,85],{},"UTBM",", reimagines the game in a student context — where players solve algorithmic puzzles to gain access to an exam room.",[64,88,89],{},[90,91],"img",{"alt":92,"className":93,"dataNoImg":95,"src":96},"Turing Machine main screen",[94],"rounded-lg","","\u002Fimages\u002Fprojects\u002Fturing-machine\u002Fcover.webp",[98,99,101],"h2",{"id":100},"technical-details","Technical details",[103,104,106],"h3",{"id":105},"technologies","Technologies",[108,109,110,120,128],"card-group",{},[111,112,117],"card",{"icon":113,"target":114,"title":115,"to":116},"i-lucide-coffee","_blank","Java","https:\u002F\u002Fwww.java.com\u002F",[64,118,119],{},"Used for the game logic, mathematical model, and overall architecture.",[111,121,125],{"icon":122,"target":114,"title":123,"to":124},"i-lucide-component","JavaFX","https:\u002F\u002Fopenjfx.io\u002F",[64,126,127],{},"Framework used to design a responsive and intuitive graphical interface.",[111,129,132],{"icon":130,"target":114,"title":131},"i-lucide-list-tree","MVC Pattern",[64,133,134],{},"The Model-View-Controller architecture ensures modularity, scalability, and maintainability.",[98,136,138],{"id":137},"project-concept","Project concept",[64,140,141,142,145,146,149,150,152,153,156],{},"Players receive a ",[67,143,144],{},"challenge email from a professor"," containing a logical ",[67,147,148],{},"riddle",".",[80,151],{},"\nTo enter the exam room, each student must find the correct ",[67,154,155],{},"password"," by proposing combinations that are tested against the rules of the riddle.",[64,158,159],{},"Each password:",[161,162,163,175,178],"ul",{},[164,165,166,167,170,171,174],"li",{},"Is ",[67,168,169],{},"unique",", generated based on the student’s ",[67,172,173],{},"INE"," (student ID)",[164,176,177],{},"Must satisfy a set of logical conditions",[164,179,180],{},"Becomes invalid after each use to prevent cheating",[64,182,183,184,187,188,191],{},"Before starting, players choose a ",[67,185,186],{},"difficulty level",", which affects both the complexity of the riddle and the ",[67,189,190],{},"score multiplier"," (from ×1.0 to ×1.8).",[64,193,194,195,198],{},"A ",[67,196,197],{},"multiplayer mode"," is also available, where students compete to find the solution first — in this case, no INE is required.",[98,200,202],{"id":201},"game-features","Game features",[161,204,205,211,217],{},[164,206,207,210],{},[67,208,209],{},"Difficulty selection"," impacting logic depth and scoring",[164,212,213,216],{},[67,214,215],{},"Validation system"," for each proposed password",[164,218,219,222],{},[67,220,221],{},"Multiplayer mode"," with real-time competition",[98,224,226],{"id":225},"core-logic","Core logic",[64,228,229,230,233],{},"To compute a unique solution, we designed a ",[67,231,232],{},"recursive functional filtering system"," that progressively narrows down possibilities.",[64,235,236],{},"Ω = { (x₁, x₂, x₃) | xᵢ ∈ {1, 2, 3, 4, 5} for i = 1, 2, 3 }",[64,238,239],{},"Each filtering function (noted f₁, f₂, f₃, …) reduces this set step by step:",[64,241,242],{},"Ωₖ = fₖ(Ωₖ₋₁)",[64,244,245,246,249],{},"The process continues until there is only one combination left (|Ωₖ| = 1).\nIf, after six filtering steps, more than one combination remains, the algorithm ",[67,247,248],{},"backtracks"," and tries a new sequence of filtering functions.",[64,251,252,253,256,257,260],{},"This guarantees that each puzzle produces a ",[67,254,255],{},"single valid solution",", determined through a logical and ",[67,258,259],{},"deterministic"," process.",[98,262,264],{"id":263},"team-responsibilities","Team responsibilities",[161,266,267,272,277],{},[164,268,269,271],{},[67,270,44],{}," — Application architecture, Game core logic, report writing",[164,273,274,276],{},[67,275,49],{}," — Sequence & class diagrams, round management sequence design, report review",[164,278,279,281],{},[67,280,54],{}," — Use case modeling, rule analysis and adaptation, report proofreading",[64,283,284,286],{},[67,285,41],{}," combines logic, mathematics, and software engineering to deliver a faithful yet original digital experience — both a technical and creative tribute to Alan Turing’s legacy.",{"title":95,"searchDepth":288,"depth":288,"links":289},2,[290,294,295,296,297],{"id":100,"depth":288,"text":101,"children":291},[292],{"id":105,"depth":293,"text":106},3,{"id":137,"depth":288,"text":138},{"id":201,"depth":288,"text":202},{"id":225,"depth":288,"text":226},{"id":263,"depth":288,"text":264},null,"A digital adaptation of the board game Turing Machine, inspired by Alan Turing and reimagined in the world of UTBM.","2025-01-12T00:00:00.000Z","md","https:\u002F\u002Fgithub.com\u002FMrArnaudMichel\u002FTuringMachineGame",{"src":96},"Java, JavaFX",{},true,"\u002Fprojects\u002Fturing-game","Project manager, developer",{"title":41,"description":299},"2024-10-15T00:00:00.000Z","3.projects\u002F008.turing-game","https:\u002F\u002Fturingmachine.arnaudmichel.fr","8XvIals2YjiCjlYPcXGN7aCFQzVYheISKISUPQBjF40",[315,320],{"title":316,"path":317,"stem":318,"description":319,"children":-1},"STM32 Analog to Digital Converter, Timers & USART","\u002Fprojects\u002Fstm32","3.projects\u002F007.stm32","Embedded systems project exploring the use of ADC, timers, and UART on an STM32 microcontroller.",{"title":321,"path":322,"stem":323,"description":324,"children":-1},"Moodle","\u002Fprojects\u002Fmoodle","3.projects\u002F009.moodle","Modern learning platform to manage courses, assignments, forums and users.",1773409594553]